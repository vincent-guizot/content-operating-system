generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id Int @id @default(autoincrement())

  name        String
  description String?
  logoImage   String?

  categories Category[]
  tags       Tag[]
  articles   Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id Int @id @default(autoincrement())

  name String
  slug String

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  articles Article[]

  createdAt DateTime @default(now())

  @@unique([slug, brandId])
  @@index([brandId])
}

model Tag {
  id Int @id @default(autoincrement())

  name String

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  articles ArticleTag[]

  createdAt DateTime @default(now())

  @@index([brandId])
}

model Article {
  id Int @id @default(autoincrement())

  title String
  slug  String @unique

  brandId Int
  brand   Brand @relation(fields: [brandId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  author String

  excerpt String?
  content String

  thumbnail  String?
  coverImage String?

  status     String
  visibility String

  featured Boolean @default(false)

  views       Int  @default(0)
  readingTime Int?

  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?

  publishedAt DateTime?
  scheduledAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tags  ArticleTag[]
  media ArticleMedia[]

  @@index([brandId])
  @@index([categoryId])
}

model ArticleTag {
  articleId Int
  tagId     Int

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model Media {
  id Int @id @default(autoincrement())

  name String
  url  String

  createdAt DateTime @default(now())

  articles ArticleMedia[]
}

model ArticleMedia {
  id Int @id @default(autoincrement())

  articleId Int
  mediaId   Int

  type String // thumbnail | cover | gallery

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id])

  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([mediaId])
}

model Notification {
  id Int @id @default(autoincrement())

  title   String
  message String

  type String // info | success | warning | error

  entity   String? // article | media | system
  entityId Int?

  isRead Boolean @default(false)

  createdAt DateTime  @default(now())
  readAt    DateTime?

  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt])
}
